# Copy to a launch command or your shell. Pick ONE backend. See bridge/README.md.

# --- Free & local: Ollama (run `ollama pull llama3.1` first) ---
# PZ_BACKEND=ollama
# PZ_MODEL=llama3.1
# OLLAMA_URL=http://localhost:11434

# --- Anthropic (Claude) ---
# ANTHROPIC_API_KEY=sk-ant-...
# PZ_MODEL=claude-haiku-4-5

# --- OpenAI (GPT) ---
# OPENAI_API_KEY=sk-...
# PZ_MODEL=gpt-4o-mini

# --- OpenAI-compatible (OpenRouter / Groq / Together / LM Studio) ---
# OPENAI_API_KEY=sk-or-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# PZ_MODEL=meta-llama/llama-3.1-70b-instruct

# --- Google Gemini ---
# GEMINI_API_KEY=...
# PZ_MODEL=gemini-1.5-flash

# --- Claude CLI (default; uses your Claude subscription) ---
# CLAUDE_BIN=/path/to/claude
# PZ_MODEL=haiku

# Optional
# PZ_TIMEOUT=45000
